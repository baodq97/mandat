{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx --yes govkit audit-write --root \"${CLAUDE_PROJECT_DIR}\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
